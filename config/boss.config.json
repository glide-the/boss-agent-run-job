{
  "account": {
    "enabled": true,
    "strategy": "manual",
    "waitForLogin": true,
    "loginCheckUrl": "https://www.zhipin.com/web/geek/chat",
    "loginCheckSelectors": [".chat-container", ".chat-list", ".friend-list"],
    "loginPollIntervalMs": 3000,
    "loginTimeoutMs": 120000,
    "description": "manual: user is expected to switch account in the browser before login wait"
  },
  "perContactChain": {
    "returnToChatMethod": "browser-back"
  },
  "chatUrl": "https://www.zhipin.com/web/geek/chat",
  "startUrl": "https://www.zhipin.com/web/geek/chat",
  "chatListScrolls": 12,
  "chatListScrollPixels": 900,
  "waitTimeoutMs": 25000,
  "screenshot": true,
  "outputDir": "output",
  "jobDetailUrlPattern": "**/job_detail/**",
  "agentBrowser": {
    "extensions": [
      "/Users/dmeck/agent-brower/capsolver-extension",
      "/Users/dmeck/agent-brower/stealth-extension"
    ],
    "state": "/Users/dmeck/agent-brower/my-auth.json",
    "headed": true,
    "resolveExecutablePath": true
  },
  "chatAreaSelectors": [
    ".chat-container",
    ".chat-content",
    "[class*='chat']"
  ],
  "conversationListSelectors": [
    ".friend-list",
    ".chat-list",
    "[class*='friend']",
    "[class*='conversation']"
  ],
  "currentChatSelectors": [
    ".chat-panel",
    ".message-list",
    "[class*='message']"
  ],
  "jobCardSelectors": [
    ".job-card",
    ".position-card",
    "[class*='job-card']",
    "[class*='position']"
  ],
  "jobDetailLinkSelectors": [
    "a[href*='/job_detail/']",
    "a[href*='job_detail']",
    "[class*='job'] a",
    "[class*='position'] a"
  ],
  "conversationEntryLocators": [
    {
      "method": "find-text",
      "value": "王攀盼",
      "description": "本次实际观察到的顶部未读会话；点击后右侧出现岗位卡片和查看职位入口"
    }
  ],
  "maxJobsPerTarget": 1,
  "traceTargets": [
    {
      "id": "target-wang-panpan",
      "description": "王攀盼会话内的有限岗位入口采集；同一浏览器 session 内按 locator 顺序尝试，重复 job_id 会被跳过",
      "maxJobs": 1,
      "conversationLocator": {
        "method": "find-text",
        "value": "王攀盼",
        "description": "本次实际观察到的顶部未读会话；点击后右侧出现岗位卡片和查看职位入口"
      },
      "jobEntryLocators": [
        {
          "method": "dom-text",
          "value": "查看职位",
          "description": "会话页中的当前岗位 CTA，直接点击可进入 job_detail"
        },
        {
          "method": "dom-text",
          "value": "职位详情",
          "description": "兼容不同会话卡片文案的岗位 CTA"
        },
        {
          "method": "css",
          "value": "a[href*='/job_detail/']",
          "description": "直接命中的岗位详情链接，作为 DOM 文本点击的 CSS 兜底"
        }
      ]
    }
  ],
  "jobEntryLocators": [
    {
      "method": "dom-text",
      "value": "查看职位",
      "description": "会话页中的当前岗位 CTA，直接点击可进入 job_detail"
    },
    {
      "method": "dom-text",
      "value": "职位详情",
      "description": "兼容不同会话卡片文案的岗位 CTA"
    },
    {
      "method": "css",
      "value": "a[href*='/job_detail/']",
      "description": "直接命中的岗位详情链接，作为 DOM 文本点击的 CSS 兜底"
    }
  ],
  "jobInfoSelectors": {
    "title": [".job-title", "[class*='job-title']", "h1"],
    "salary": [".salary", "[class*='salary']", "[class*='red']"],
    "requirements": [".job-banner", ".job-primary", "[class*='job-primary']"],
    "description": [".job-sec-text", ".job-detail-section", "[class*='job-sec']"],
    "company": [".company-info", "[class*='company']"],
    "recruiter": [".boss-info", "[class*='boss']", "[class*='recruiter']"]
  },
  "excludedJobSectionHeadings": [
    "相似职位",
    "更多相似职位",
    "精选职位",
    "看过该职位的人还看了",
    "城市招聘",
    "热门职位",
    "推荐公司",
    "热门企业",
    "其它公司品牌信息",
    "其他公司品牌信息"
  ],
  "returnToChat": {
    "method": "browser-back"
  },
  "fieldHints": {
    "salary": ["K", "薪", "元/月"],
    "requirements": ["经验", "学历", "本科", "大专", "不限"],
    "company": ["公司", "集团", "科技", "网络", "信息"]
  }
}
